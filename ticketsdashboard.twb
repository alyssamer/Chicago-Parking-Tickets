                <run bold='true'>: Notice of violation sent</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#898989'>SEIZ</run>
                <run bold='true'>: Vehicle is on boot list</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#898989'>DETR</run>
                <run bold='true'>: Hearing officer found owner liable</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#898989'>FINL</run>
                <run bold='true'>: Unpaid ticket sent to collections</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#898989'>DLS</run>
                <run bold='true'>: Intent of license suspension</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#898989'>NONE</run>
                <run bold='true'>: No notice sent</run>
              </formatted-text>
            </customized-tooltip>
