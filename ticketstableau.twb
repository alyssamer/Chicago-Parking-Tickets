      <aliases enabled='yes' />
      <column caption='Ticket Status' datatype='string' name='[Calculation_0377425642803200]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ticket_queue] = &apos;Paid&apos; THEN &apos;Paid&apos;&#13;&#10;ELSEIF [ticket_queue] = &apos;Dismissed&apos; THEN &apos;Dismissed&apos;&#13;&#10;ELSE &apos;Unpaid&apos;&#13;&#10;END' />
      </column>
      <column caption='Payment Rate' datatype='real' name='[Calculation_0377425701646340]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_0377425642803200] = &apos;Paid&apos; THEN 1 ELSE 0 END) / COUNT([ticket_queue])' />
      </column>
      <column caption='Unpaid Rate' datatype='real' name='[Calculation_0377425717063685]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_0377425642803200] = &apos;Unpaid&apos; THEN 1 ELSE 0 END) / COUNT([ticket_queue])' />
      </column>
      <column caption='Dismissed Rate' datatype='real' name='[Calculation_0377425718075399]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_0377425642803200] = &apos;Dismissed&apos; THEN 1 ELSE 0 END) / COUNT([ticket_queue])' />
      </column>
      <column caption='Unpaid Revenue' datatype='real' name='[Calculation_0377425724256265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({FIXED [year] : SUM(IF [Calculation_0377425642803200] = &apos;Unpaid&apos; THEN [fine_level2_amount] ELSE 0 END)})' />
      </column>
      <column caption='UnTicket CNT' datatype='real' name='[Calculation_0377425735725067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({FIXED [year] : SUM(IF [Calculation_0377425642803200] = &apos;Unpaid&apos; THEN 1 ELSE 0 END)})' />
      </column>
      <column caption='sample.csv' datatype='table' name='[__tableau_internal_object_id__].[sample.csv_D33B286442004F3CB66A5C370C9CC7FB]' role='measure' type='quantitative' />
